# Application mode
APP_ENV=development
LOG_LEVEL=INFO

# Local database
# Preferred default for MVP:
DATABASE_URL=sqlite:///data/research_digest.db

# Config paths
TOPICS_CONFIG_PATH=config/topics.yaml

# Digest behavior
DIGEST_OUTPUT_DIR=output
DIGEST_TIMEZONE=America/New_York
DIGEST_MAX_ITEMS=10

# Summarization mode
# Allowed values: extractive | llm
SUMMARY_MODE=extractive

# LLM provider
# Allowed values: none | anthropic | openai
LLM_PROVIDER=none

# Optional provider keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional notification layer
NOTIFICATIONS_ENABLED=false
EMAIL_PROVIDER=none
EMAIL_API_KEY=
EMAIL_FROM=
EMAIL_TO=
SLACK_WEBHOOK_URL=

# Notes:
# - Copy this file to `.env` only when the implementation actually needs it.
# - Never commit real secrets.
# - Prefer replying "done" to Claude after placing secrets locally, instead of pasting secrets into chat.